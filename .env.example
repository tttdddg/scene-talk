# SceneTalk 环境变量

# 前端
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=SceneTalk

# 后端
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# 视觉模型
VISION_API_KEY=
